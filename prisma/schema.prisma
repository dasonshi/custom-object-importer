generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Install {
  id           String   @id @default(cuid())
  locationId   String   @unique @map("location_id")
  companyId    String?  @map("company_id")    // Company ID for fallback auth when encryptedData fails
  accessToken  String   @map("access_token")  // Encrypted
  refreshToken String   @map("refresh_token") // Encrypted
  expiresAt    BigInt   @map("expires_at")    // Store as timestamp
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("installs")
  @@index([locationId])
  @@index([companyId])
}

model AgencyInstall {
  id            String   @id @default(cuid())
  companyId     String   @unique @map("company_id")
  encryptedData String   @map("encrypted_data")  // Encrypted JSON with agency tokens and locations
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("agency_installs")
  @@index([companyId])
}

model UsageCounter {
  id           String   @id @default(cuid())
  locationId   String   @unique @map("location_id")
  requestCount Int      @default(0) @map("request_count")
  lastRequest  DateTime @updatedAt @map("last_request")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("usage_counters")
}